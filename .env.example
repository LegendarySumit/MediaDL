# ============================================================================
# MediaDL - Complete Environment Variables Template
# Copy this to .env, .env.development, or .env.production and fill in your values
# ============================================================================

# ─── REDIS CONFIGURATION ───────────────────────────────────────────────────
# Backend uses Redis for job queue, caching, and session management

# Option 1: Direct Redis URL (recommended for cloud deployment)
REDIS_URL=redis://localhost:6379

# Option 2: Redis connection details (fallback, used if REDIS_URL not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── FRONTEND APPLICATION ─────────────────────────────────────────────────

# Public-facing base URL for API calls from frontend
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Production frontend origin (used by backend for CORS allowlisting)
FRONTEND_ORIGIN=https://media-dl.vercel.app

# reCAPTCHA v3 site key (optional, required if CAPTCHA_REQUIRED=true with reCAPTCHA)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Cloudflare Turnstile site key (optional, use this if backend uses TURNSTILE_SECRET_KEY)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ─── BACKEND SERVER ───────────────────────────────────────────────────────

# Express server listening port
PORT=3001

# Environment: development, test, or production
NODE_ENV=development

# ─── CAPTCHA & ANTI-BOT PROTECTION ────────────────────────────────────────

# Enable captcha verification for /api/info and /api/jobs endpoints
CAPTCHA_REQUIRED=false

# Cloudflare Turnstile secret key (if using Turnstile for captcha)
TURNSTILE_SECRET_KEY=

# Google reCAPTCHA v3 secret key (if using reCAPTCHA for captcha)
RECAPTCHA_SECRET_KEY=

# ─── YOUTUBE AUTHENTICATION ───────────────────────────────────────────────

# Single cookie string in Netscape format
# Can be base64-encoded or plain text
# Obtain from browser: DevTools → Storage → Cookies → youtube.com → Export Netscape Format
YOUTUBE_COOKIES=

# Optional cookies file path on server (Netscape format)
# Example: ./backend/cookies.txt
YOUTUBE_COOKIES_PATH=

# Pool of cookies (JSON array or comma-separated strings)
# Rotates cookies across failed attempts to bypass rate limiting
# Example 1: ["cookie1...", "cookie2...", "cookie3..."]
# Example 2: cookie1..., cookie2..., cookie3...
YOUTUBE_COOKIES_POOL=

# ─── PROXY CONFIGURATION ──────────────────────────────────────────────────

# Single HTTP proxy URL (residential or datacenter)
# Used to bypass YouTube IP blocks and rate limiting
# Example: http://user:pass@proxy.example.com:8080
YOUTUBE_PROXY=

# Fallback proxy (if YOUTUBE_PROXY is blocked)
PROXY=

# Pool of proxies (JSON array or comma-separated URLs)
# Rotates proxies across failed attempts
# Example: ["http://proxy1:8080", "http://proxy2:8080", "http://proxy3:8080"]
YOUTUBE_PROXY_POOL=

# ─── DOWNLOAD MANAGEMENT ──────────────────────────────────────────────────

# How long to keep downloaded files before auto-cleanup (minutes)
# Default: 60 minutes (1 hour)
DOWNLOAD_TTL_MINUTES=60

# Number of parallel download workers to process jobs
# Default: 2 (adjust based on server CPU/memory)
DOWNLOAD_WORKER_CONCURRENCY=2

# Number of times to retry a failed download job
# Default: 3 (retries with different player clients, proxies, cookies)
DOWNLOAD_JOB_ATTEMPTS=3

# ─── LOGGING ──────────────────────────────────────────────────────────────

# Log level: trace, debug, info, warn, error, fatal
# Default: info
LOG_LEVEL=info

# ─── TESTING ──────────────────────────────────────────────────────────────

# Disable Redis queue in test environment (use in-memory mode)
# Set to 'true' when running Jest tests to avoid Redis dependency
DISABLE_QUEUE=false

# ============================================================================
# DEPLOYMENT REFERENCES
# ============================================================================

# Vercel (Frontend):
# - NEXT_PUBLIC_API_BASE: point to your Render backend URL
# - NEXT_PUBLIC_RECAPTCHA_SITE_KEY: if captcha enabled

# Render (Backend):
# - REDIS_URL: Render managed Redis connection string
# - FRONTEND_ORIGIN: your Vercel frontend URL for CORS
# - CAPTCHA_REQUIRED, TURNSTILE_SECRET_KEY / RECAPTCHA_SECRET_KEY
# - All YOUTUBE_* vars for auth and proxy

# Local Development:
# - REDIS_HOST: localhost (start Redis with: redis-server or docker)
# - NEXT_PUBLIC_API_BASE: http://localhost:3001
# - NODE_ENV: development

# Local Testing:
# - NODE_ENV: test
# - DISABLE_QUEUE: true
# - All others can use defaults

# ============================================================================
# OPTIONAL / ADVANCED
# ============================================================================

# Rate limiting per IP (requests per 15 minutes)
# API_RATE_LIMIT=100

# Rate limiting for downloads (per hour)
# DOWNLOAD_RATE_LIMIT=20

# Custom download directory (default: backend/downloads)
# DOWNLOADS_DIR=/custom/path

# ============================================================================
# SECURITY NOTES
# ============================================================================

# - NEVER commit .env files to git (add to .gitignore)
# - Use environment secrets in CI/CD pipelines (GitHub Actions)
# - Regenerate secrets regularly in production
# - Keep YOUTUBE_COOKIES and PROXY_PASSWORDS private
# - Use HTTPS in production (Render auto-provides Let's Encrypt)
# - Monitor logs for failed auth attempts (signals attacks)
